{
  "name": "oc-test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "scripts": {
    "start": "tsx watch --exclude docs --exclude logs src/utils/discord-client.ts",
    "dev:backend": "npm start",
    "dev:dashboard": "npm run dev --prefix dashboard",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:dashboard\"",
    "build:dashboard": "npm run build --prefix dashboard",
    "preview": "serve .",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "bugs": {
    "url": "https://github.com/kei-takamatsu/oc-test/issues"
  },
  "homepage": "https://github.com/kei-takamatsu/oc-test#readme",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.6",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/sqlite3": "^3.1.11",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
