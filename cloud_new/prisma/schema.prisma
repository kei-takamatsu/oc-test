generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               Int      @id @default(autoincrement())
  nickname         String   @map("nick_name")
  name             String?
  email            String   @unique
  emailVerified    DateTime? @map("email_verified")
  password         String?  // Social login might not have a password
  image            String?
  sex              String?
  address          String?
  birthday         DateTime?
  selfDescription  String?  @map("self_description")
  receiveAddress   String?  @map("receive_address")
  twitterId        String?  @map("twitter_id")
  facebookId       String?  @map("facebook_id")
  active           Boolean  @default(true)
  loginTryCount    Int      @default(0) @map("login_try_count")
  
  accounts         Account[]
  sessions         Session[]
  projects         Project[]
  backedProjects   BackedProject[]
  comments         Comment[]
  messagesSent     Message[]       @relation("SentMessages")
  messagesReceived Message[]       @relation("ReceivedMessages")
  favorites        Favorite[]
  notifications    Notification[]
  
  createdAt        DateTime @default(now()) @map("created")
  updatedAt        DateTime @updatedAt @map("modified")

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             Int     @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? 
  access_token       String? 
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? 
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                  Int      @id @default(autoincrement())
  projectName         String   @map("project_name")
  description         String  
  goalAmount          Int      @map("goal_amount")
  collectedAmount     Int      @default(0) @map("collected_amount")
  collectionTerm      Int      @default(60) @map("collection_term")
  collectionStartDate DateTime? @map("collection_start_date")
  collectionEndDate   DateTime? @map("collection_end_date")
  opened              String   @default("no") // "no", "yes"
  active              String   @default("yes")
  backers             Int      @default(0)
  imageUrl            String?  @map("image_url")
  
  categoryId          Int?     @map("category_id")
  category            Category? @relation(fields: [categoryId], references: [id])
  areaId              Int?     @map("area_id")
  area                Area?     @relation(fields: [areaId], references: [id])

  ownerId             Int      @map("user_id")
  owner               User     @relation(fields: [ownerId], references: [id])
  
  backingLevels       BackingLevel[]
  backedProjects      BackedProject[]
  comments            Comment[]
  reports             Report[]
  activityReports     ActivityReport[]
  favorites           Favorite[]
  
  createdAt           DateTime @default(now()) @map("created")
  updatedAt           DateTime @updatedAt @map("modified")

  @@map("projects")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  projects  Project[]

  @@map("categories")
}

model Area {
  id        Int       @id @default(autoincrement())
  name      String
  projects  Project[]

  @@map("areas")
}

model BackingLevel {
  id            Int      @id @default(autoincrement())
  projectId     Int      @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id])
  name          String
  investAmount  Int      @map("invest_amount")
  returnAmount  String   @map("return_amount")
  maxCount      Int?     @map("max_count")
  nowCount      Int      @default(0) @map("now_count")
  delivery      Int      @default(1) // 1:メール, 2:郵送E 3:対面
  
  backedProjects BackedProject[]
  
  createdAt     DateTime @default(now()) @map("created")
  updatedAt     DateTime @updatedAt @map("modified")

  @@map("backing_levels")
}

model BackedProject {
  id              Int      @id @default(autoincrement())
  projectId       Int      @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  backingLevelId  Int      @map("backing_level_id")
  backingLevel    BackingLevel @relation(fields: [backingLevelId], references: [id])
  
  investAmount    Int      @map("invest_amount")
  comment         String? 
  status          String   @default("pending") // pending, authorized, captured, canceled
  
  // Stripe integration
  stripePaymentId String?  @map("stripe_payment_id")
  
  createdAt       DateTime @default(now()) @map("created")
  updatedAt       DateTime @updatedAt @map("modified")

  @@map("backed_projects")
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  projectId Int      @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  content   String   @map("comment")
  createdAt DateTime @default(now()) @map("created")

  @@map("comments")
}

model Report {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  title     String
  open      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created")
  updatedAt DateTime @updatedAt @map("modified")

  @@map("reports")
}

model Message {
  id         Int      @id @default(autoincrement())
  fromId     Int      @map("from_id")
  from       User     @relation("SentMessages", fields: [fromId], references: [id])
  toId       Int      @map("to_id")
  to         User     @relation("ReceivedMessages", fields: [toId], references: [id])
  content    String  
  createdAt  DateTime @default(now()) @map("created")

  @@map("messages")
}

model ActivityReport {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created")

  @@map("activity_reports")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  projectId Int      @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now()) @map("created")

  @@unique([userId, projectId])
  @@map("favorites")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "support", "comment", "activity_report"
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created")

  @@map("notifications")
}
